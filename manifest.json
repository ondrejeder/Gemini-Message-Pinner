{
  "manifest_version": 3,
  "name": "Gemini Chat Pinner",
  "version": "1.0",
  "description": "Pin Gemini responses to a sidebar for easy reference.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*", "*://www.google.com/search?*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}